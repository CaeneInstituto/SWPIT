# ─── Culqi - Claves de PRUEBA (no cobran dinero real) ─────────────────────────
# Copia este archivo como .env y reemplaza con tus claves reales
# Obtén tus claves en: https://dashboard.culqi.com → Desarrollo → API Keys

# Clave PÚBLICA (va en el frontend - empieza con pk_test_ o pk_live_)
VITE_CULQI_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXX

# Clave SECRETA (solo en el backend - empieza con sk_test_ o sk_live_)
CULQI_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXX

# URL del servidor backend
VITE_API_URL=http://localhost:3001
